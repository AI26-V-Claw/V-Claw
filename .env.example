# V-Claw local environment example.
# Copy this file to .env for local development. Never commit real tokens.

# OpenAI provider for G5 agent runtime.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Intent classifier mode.
# fallback: use LLM first, then heuristic if classifier LLM fails.
# llm: use only LLM classifier.
# heuristic: use heuristic classifier for quick local testing.
VCLAW_INTENT_CLASSIFIER_MODE=fallback

# Short-term session memory.
# memory: keep transcript in process memory only.
# redis: persist short-term transcript in Redis by sessionId.
# If VCLAW_SESSION_STORE is empty but VCLAW_REDIS_URL is set, Redis is used.
VCLAW_SESSION_STORE=memory
VCLAW_REDIS_URL=redis://localhost:6379/0
VCLAW_REDIS_KEY_PREFIX=vclaw:session:
VCLAW_SESSION_MAX_MESSAGES=40
VCLAW_SESSION_TTL_SECONDS=86400

# Telegram channel, created via @BotFather.
TELEGRAM_BOT_TOKEN=
ALLOWED_TELEGRAM_USER_ID=
DATA_DIR=./data
LOG_DIR=./logs

# Slack channel using Socket Mode.
VCLAW_SLACK_ENABLED=false
VCLAW_SLACK_BOT_TOKEN=
VCLAW_SLACK_APP_TOKEN=
VCLAW_SLACK_OWNER_USER_ID=
VCLAW_SLACK_ALLOWED_CHANNEL_IDS=

# Google Workspace OAuth paths.
VCLAW_GOOGLE_CREDENTIALS_PATH=configs/google/credentials.json
VCLAW_GOOGLE_TOKEN_PATH=configs/google/token.json
VCLAW_GOOGLE_WORKSPACE_DOMAINS=vclaw.site

# Demo tool wiring.
# auto: register Google tools only when credentials/token files exist.
# required: fail startup if Google OAuth is not ready.
# off: expose built-in and sandbox approval tools only.
VCLAW_GOOGLE_TOOLS_MODE=auto

# Web search/fetch via Tavily.
# auto: register web tools only when TAVILY_API_KEY is set.
# required: fail startup if Tavily is not configured.
# off: do not expose web search/fetch tools.
VCLAW_WEB_TOOLS_MODE=auto
TAVILY_API_KEY=

# Database
# Local/dev database defaults. Keep real credentials in .env, which is ignored.
VCLAW_POSTGRES_DB=vclaw
VCLAW_POSTGRES_USER=vclaw
VCLAW_POSTGRES_PASSWORD=vclaw
VCLAW_DATABASE_TIMEZONE=Asia/Ho_Chi_Minh

# Use this when running V-Claw from the host machine while PostgreSQL is
# published by Docker Compose on localhost:5432.
DATABASE_URL=postgres://vclaw:vclaw@localhost:5432/vclaw?sslmode=disable
# If V-Claw itself runs inside docker-compose, use the service name instead:
# DATABASE_URL=postgres://vclaw:vclaw@postgres:5432/vclaw?sslmode=disable
