# V-Claw local environment example.
# Copy this file to .env for local development. Never commit real tokens.

# OpenAI provider for G5 agent runtime.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Telegram channel, created via @BotFather.
VCLAW_TELEGRAM_ENABLED=false
VCLAW_TELEGRAM_BOT_TOKEN=
VCLAW_TELEGRAM_ALLOWED_USER_IDS=
VCLAW_TELEGRAM_ALLOWED_CHAT_IDS=

# Slack channel using Socket Mode.
VCLAW_SLACK_ENABLED=false
VCLAW_SLACK_BOT_TOKEN=
VCLAW_SLACK_APP_TOKEN=
VCLAW_SLACK_ALLOWED_CHANNEL_IDS=
VCLAW_SLACK_ALLOWED_USER_IDS=

# Google Workspace OAuth paths.
VCLAW_GOOGLE_CREDENTIALS_PATH=configs/google/credentials.json
VCLAW_GOOGLE_TOKEN_PATH=configs/google/token.json
VCLAW_GOOGLE_WORKSPACE_DOMAINS=vclaw.site
