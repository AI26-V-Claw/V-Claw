# V-Claw local environment example.
# Copy this file to .env for local development. Never commit real tokens.

# OpenAI provider for G5 agent runtime.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=
# Vision image input. User-sent images are sent to providers that support image
# input; raw image bytes/base64 are not stored in transcript or memory.
VCLAW_VISION_DETAIL=auto
VCLAW_VISION_MAX_IMAGES=4
VCLAW_VISION_MAX_IMAGE_BYTES=10485760
VCLAW_VISION_MAX_TOTAL_BYTES=20971520
# Used by session compaction and lightweight long-term memory classifiers.
VCLAW_COMPACTOR_MODEL=gpt-4o-mini

# Intent classifier mode.
# fallback: use LLM first, then heuristic if classifier LLM fails.
# llm: use only LLM classifier.
# heuristic: use heuristic classifier for quick local testing.
VCLAW_INTENT_CLASSIFIER_MODE=fallback

# Agent timezone (IANA name, e.g. Asia/Ho_Chi_Minh, America/New_York).
# Controls how the bot displays dates/times (Gmail send time, Drive modifiedTime)
# and resolves relative dates like "today" / "this week". Defaults to
# Asia/Ho_Chi_Minh when unset. This is NOT the same as VCLAW_DATABASE_TIMEZONE,
# which only sets the PostgreSQL container timezone.
VCLAW_TIMEZONE=Asia/Ho_Chi_Minh

# Parallel execution for batches containing only safe read/compute tools.
VCLAW_PARALLEL_ENABLED=false
VCLAW_PARALLEL_MAX_WORKERS=4
VCLAW_PARALLEL_TOOL_TIMEOUT=30s

# Telegram channel, created via @BotFather.
TELEGRAM_BOT_TOKEN=
ALLOWED_TELEGRAM_USER_ID=
DATA_DIR=./data
LOG_DIR=./logs

# Slack channel using Socket Mode.
VCLAW_SLACK_ENABLED=false
VCLAW_SLACK_BOT_TOKEN=
VCLAW_SLACK_APP_TOKEN=
VCLAW_SLACK_OWNER_USER_ID=
VCLAW_SLACK_ALLOWED_CHANNEL_IDS=

# Google Workspace OAuth paths.
VCLAW_GOOGLE_CREDENTIALS_PATH=configs/google/credentials.json
VCLAW_GOOGLE_TOKEN_PATH=configs/google/token.json
VCLAW_GOOGLE_WORKSPACE_DOMAINS=vclaw.site

# Demo tool wiring.
# auto: register Google tools only when credentials/token files exist.
# required: fail startup if Google OAuth is not ready.
# off: expose built-in and sandbox approval tools only.
VCLAW_GOOGLE_TOOLS_MODE=auto

# Web search/fetch via Tavily.
# auto: register web tools only when TAVILY_API_KEY is set.
# required: fail startup if Tavily is not configured.
# off: do not expose web search/fetch tools.
VCLAW_WEB_TOOLS_MODE=auto
TAVILY_API_KEY=

# Langfuse observability.
# Leave blank to disable tracing export.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_PROJECT_ID=

# Database
# Local/dev database defaults. Keep real credentials in .env, which is ignored.
VCLAW_POSTGRES_DB=vclaw
VCLAW_POSTGRES_USER=vclaw
VCLAW_POSTGRES_PASSWORD=vclaw
# PostgreSQL container timezone only. To change the bot's display timezone,
# set VCLAW_TIMEZONE above instead.
VCLAW_DATABASE_TIMEZONE=Asia/Ho_Chi_Minh


# Choose one of the following DATABASE_URL options based on your setup:
# A) Docker Compose (container published on host port 5433):
DATABASE_URL=postgres://vclaw:vclaw@localhost:5433/vclaw?sslmode=disable

# B) PostgreSQL local / native (default port 5432):
# DATABASE_URL=postgres://vclaw:vclaw@localhost:5432/vclaw?sslmode=disable
