                                   "decision":  "approve",
                                   "reason":  "Approve Docs write."
                               },
                               {
                                   "when":  "next_approval_requested",
                                   "decision":  "approve",
                                   "reason":  "Approve Sheets write."
                               },
                               {
                                   "when":  "next_approval_requested",
                                   "decision":  "approve",
                                   "reason":  "Approve Gmail draft write."
                               },
                               {
                                   "when":  "possible_extra_approval",
                                   "decision":  "approve",
                                   "reason":  "Approve one extra continuation write if the agent splits Docs/Sheets updates."
                               }
                           ],
    "expected_tool_sequence":  {
                                   "required_any_order":  [
                                                              "gmail.listEmails",
                                                              "calendar.listEvents",
                                                              "drive.listFiles",
                                                              "drive.createFile",
                                                              "docs.createDocument",
                                                              "sheets.createSpreadsheet",
                                                              "gmail.createDraft"
